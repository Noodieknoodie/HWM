{
  "name": "hwm-401k-tracker",
  "version": "1.0.0",
  "description": "HWM 401k Tracker - Full Stack Application",
  "private": true,
  "scripts": {
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && python run_tests.py",
    "test:frontend": "cd frontend && npm test",
    "test:frontend:ui": "cd frontend && npm run test:ui",
    "test:frontend:coverage": "cd frontend && npm run test:coverage",
    "test:backend:coverage": "cd backend && python -m pytest --cov=app --cov-report=html",
    "install:all": "npm run install:backend && npm run install:frontend",
    "install:backend": "cd backend && pip install -r requirements.txt",
    "install:frontend": "cd frontend && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && uvicorn app.main:app --reload",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Noodieknoodie/HWM.git"
  },
  "keywords": [
    "401k",
    "tracker",
    "fastapi",
    "react",
    "typescript",
    "azure"
  ],
  "author": "Noodieknoodie",
  "license": "UNLICENSED"
}